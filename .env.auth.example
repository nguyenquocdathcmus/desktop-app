# Copy file này thành .env.auth và điền thông tin thật.
# KHÔNG commit file .env.auth lên git.
#
# Giá trị mặc định bên dưới (SUPABASE_URL/SUPABASE_ANON_KEY) là giá trị CỐ ĐỊNH
# mà `supabase start` luôn in ra cho môi trường local (Docker) — không phải bí
# mật thật, chỉ hoạt động trên máy bạn. Khi chuyển sang Supabase Cloud, thay
# bằng URL + anon key thật của project (xem docs/SETUP_SUPABASE.md).

# --- Supabase ---
SUPABASE_URL="http://127.0.0.1:54331"
SUPABASE_ANON_KEY="sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH"

# --- Paddle (xem docs/SETUP_PADDLE.md) ---
# 'sandbox' trong lúc phát triển/test, 'production' khi lên thật.
PADDLE_ENV="sandbox"
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
# ID của Price đã tạo trong Paddle dashboard cho gói Pro.
PADDLE_PRO_PRICE_ID=""
